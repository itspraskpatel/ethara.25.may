generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  ipAddress String
  name      String
  email     String?
  createdAt DateTime @default(now())

  @@index([ipAddress])
  @@index([createdAt])
}